[
  {
    "id": "immortal_path_qi_desc",
    "type": "widget",
    "style": "text",
    "label": "境界",
    "//en_us_label": "Realm",
    "//": "文字描述：显示当前炼气境层数（未入门 / 一层~十三层）。用 clauses + math 判定。/ Text descriptor: current Qi Refining layer.",
    "flags": [ "W_DISABLED_WHEN_EMPTY" ],
    "clauses": [
      {
        "id": "uninitiated",
        "text": "未入门",
        "//en_us_text": "Uninitiated",
        "color": "c_dark_gray",
        "condition": { "math": [ "u_spell_level('realm_qi_refining') < 0" ] }
      },
      {
        "id": "qi_refining",
        "text": "炼气 <u_val:qi_refining_layer> 层",
        "//en_us_text": "Qi Refining, layer N",
        "color": "c_light_cyan",
        "parse_tags": true,
        "condition": { "math": [ "u_spell_level('realm_qi_refining') >= 0" ] }
      }
    ]
  },
  {
    "id": "immortal_path_qi_num",
    "type": "widget",
    "style": "number",
    "label": "灵气",
    "//en_us_label": "Qi",
    "//": "灵气数值 widget：当前灵气 / 动态上限。值与上限均走 math 内置接口。/ Qi number widget: current qi over dynamic cap.",
    "var": "custom",
    "custom_var": { "value": { "math": [ "u_vitamin('qi')" ] }, "range": [ 0, { "math": [ "immortal_path_qi_max()" ] } ] },
    "colors": [ "c_light_blue", "c_cyan", "c_light_cyan" ]
  },
  {
    "id": "immortal_path_qi_power_num",
    "type": "widget",
    "style": "number",
    "label": "灵气强度",
    "//en_us_label": "Qi power",
    "//": "灵气强度数值 widget：显示 qi_power 通道当前值（基础 100、炼气圆满约 196）。它是攻击/破坏类法术威力的绝对评判标准之一——法术伤害取 qi_power/100 作系数,值越高威力越大。仅在已入门（有炼气士特性、qi_power 偏离基础 100）时有意义,故 W_DISABLED_WHEN_EMPTY 配合范围。值走 jmath immortal_path_qi_power,与火弹术伤害同源。/ Qi power number widget: the qi_power channel value (base 100, ~196 at full Qi Refining). One of the absolute power metrics for attack arts; damage uses qi_power/100 as a multiplier. Same jmath source as Fireball damage.",
    "var": "custom",
    "custom_var": {
      "value": { "math": [ "immortal_path_qi_power()" ] },
      "range": [ 100, { "math": [ "max( 100, immortal_path_qi_power() )" ] } ]
    },
    "colors": [ "c_yellow", "c_light_red", "c_red" ]
  },
  {
    "id": "immortal_path_qi_graph",
    "type": "widget",
    "style": "graph",
    "label": "灵气",
    "//en_us_label": "Qi",
    "//": "灵气进度条 widget：按动态上限自动缩放（range 上限调用 jmath immortal_path_qi_max，与 qi_clamp EOC 同源）。/ Qi graph widget: scales to the dynamic cap via the shared jmath function.",
    "var": "custom",
    "custom_var": { "value": { "math": [ "u_vitamin('qi')" ] }, "range": [ 0, { "math": [ "immortal_path_qi_max()" ] } ] },
    "width": 20,
    "symbols": ".oO0",
    "fill": "bucket",
    "colors": [ "c_blue", "c_light_blue", "c_cyan", "c_light_cyan" ]
  },
  {
    "id": "immortal_path_qi_desc_layout",
    "type": "widget",
    "style": "layout",
    "arrange": "columns",
    "label": "境界",
    "//en_us_label": "Realm",
    "//": "境界文字分区。顶层 layout 需带 label——它是侧边栏排序栏里显示的名字（原版顶层 layout 如 Stats/Movement 皆有 label）。/ Realm descriptor section. Top-level layouts need a label: it's the name shown in the sidebar options/sort menu.",
    "widgets": [ "immortal_path_qi_desc" ]
  },
  {
    "id": "immortal_path_qi_num_layout",
    "type": "widget",
    "style": "layout",
    "arrange": "columns",
    "label": "灵气",
    "//en_us_label": "Qi",
    "//": "灵气数值分区。/ Qi number section.",
    "widgets": [ "immortal_path_qi_num" ]
  },
  {
    "id": "immortal_path_qi_power_layout",
    "type": "widget",
    "style": "layout",
    "arrange": "columns",
    "label": "灵气强度",
    "//en_us_label": "Qi power",
    "//": "灵气强度数值分区。/ Qi power number section.",
    "widgets": [ "immortal_path_qi_power_num" ]
  },
  {
    "id": "immortal_path_qi_graph_layout",
    "type": "widget",
    "style": "layout",
    "arrange": "columns",
    "label": "灵气槽",
    "//en_us_label": "Qi bar",
    "//": "灵气进度条分区。label 用「灵气槽」与数值分区「灵气」区分，避免排序栏出现两个同名「灵气」。/ Qi graph section. Labeled distinctly from the Qi number section so the sort menu doesn't show two identical 'Qi' entries.",
    "widgets": [ "immortal_path_qi_graph" ]
  },
  {
    "copy-from": "custom_sidebar",
    "type": "widget",
    "id": "custom_sidebar",
    "//": "把灵气分区 extend 进各原版侧边栏预设。/ Extend each vanilla sidebar preset with the qi sections.",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "legacy_classic_sidebar",
    "type": "widget",
    "id": "legacy_classic_sidebar",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "legacy_compact_sidebar",
    "type": "widget",
    "id": "legacy_compact_sidebar",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "legacy_labels_narrow_sidebar",
    "type": "widget",
    "id": "legacy_labels_narrow_sidebar",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "legacy_labels_sidebar",
    "type": "widget",
    "id": "legacy_labels_sidebar",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "my_labels_sidebar",
    "type": "widget",
    "id": "my_labels_sidebar",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  },
  {
    "copy-from": "my_labels_sidebar_cleaner",
    "type": "widget",
    "id": "my_labels_sidebar_cleaner",
    "extend": {
      "widgets": [
        "immortal_path_qi_desc_layout",
        "immortal_path_qi_num_layout",
        "immortal_path_qi_power_layout",
        "immortal_path_qi_graph_layout"
      ]
    }
  }
]
