[
  {
    "type": "effect_on_condition",
    "id": "EOC_immortal_path_bind_realm_trait",
    "//": "「法术派系即变异」的即时绑定：监听 character_learns_spell 事件，一旦学会炼气境 spell（realm_qi_refining）就授予其 spell_class 特性 immortal_path_qi_cultivator。引擎在 learn_spell 路径会自动 set_mutation(spell_class)，但 set_spell_level 路径不会——本 EOC 补上这条，使无论以何种方式获得境界 spell，载体特性都到位。事件 EOC 的 spell id 通过上下文变量传入。/ Event-driven binding: when the realm spell is learned by any path, grant its spell_class trait (the engine only auto-grants via learn_spell, not set_spell_level).",
    "eoc_type": "EVENT",
    "required_event": "character_learns_spell",
    "condition": {
      "and": [
        { "math": [ "u_spell_level('realm_qi_refining') > -1" ] },
        { "not": { "u_has_trait": "immortal_path_qi_cultivator" } }
      ]
    },
    "effect": [ { "u_add_trait": "immortal_path_qi_cultivator" } ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_immortal_path_ensure_realm_trait",
    "//": "定期检测兜底：RECURRING 周期检查「已会炼气境 spell 但缺炼气士特性」的角色并补发。覆盖两种漏发场景：(1) 旧存档——角色在本特性机制加入前就已修炼，game_avatar_new 与 learn 事件都已错过；(2) 任何其它途径授予境界 spell 时的遗漏。幂等：有特性即跳过。与即时绑定 EOC 并行，双保险。/ RECURRING safety net: periodically grant the carrier trait to anyone who knows the realm spell but lacks it. Covers old saves (predating this trait) and any missed grant path. Idempotent.",
    "recurrence": [ "30 seconds", "90 seconds" ],
    "global": true,
    "run_for_npcs": false,
    "condition": {
      "and": [
        { "math": [ "u_spell_level('realm_qi_refining') > -1" ] },
        { "not": { "u_has_trait": "immortal_path_qi_cultivator" } }
      ]
    },
    "effect": [ { "u_add_trait": "immortal_path_qi_cultivator" } ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_immortal_path_ensure_basic_elixir_recipe",
    "//": "炼气入门后授予基础聚气丹配方。用 RECURRING 兜底，覆盖旧存档与任何非 learn_spell 路径获得境界 spell 的角色；已有配方则跳过。/ Grant the basic Qi-Gathering Pill recipe after entering Qi Refining. RECURRING covers old saves and any non-learn_spell grant path; skip if already known.",
    "recurrence": [ "30 seconds", "90 seconds" ],
    "global": true,
    "run_for_npcs": false,
    "condition": {
      "and": [
        { "math": [ "u_spell_level('realm_qi_refining') > -1" ] },
        { "not": { "u_know_recipe": "immortal_path_qi_gathering_pill" } }
      ]
    },
    "effect": [ { "u_learn_recipe": "immortal_path_qi_gathering_pill" } ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_immortal_path_bind_art_traits",
    "//": "学功法即授五行/魔功载体特性：监听 character_learns_spell，按已会的吐纳变体 spell 分支授予对应载体特性（草木同春/阳炎附骨/…）。各分支幂等（已有特性即跳过 u_add_trait 不重复）。这些载体特性携带五行被动 enchantment（含属性极化）；境界进度共用 realm_qi_refining，与本绑定无关（境界特性炼气士由上面的 EOC 单独授予）。一个角色可同时修炼多门功法、叠加多个载体特性——是否限制「只能主修一门」留待后续设计。/ Grant the elemental/demonic carrier trait when its breathing variant is learned. Each branch is idempotent. Multiple arts can stack for now; 'one core method only' is a later design choice.",
    "eoc_type": "EVENT",
    "required_event": "character_learns_spell",
    "effect": [
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_evergreen') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_evergreen" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_evergreen" }, { "u_learn_recipe": "immortal_path_evergreen_pill" } ]
      },
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_blazing_sun') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_blazing_sun" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_blazing_sun" } ]
      },
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_deep_earth') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_deep_earth" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_deep_earth" } ]
      },
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_true_metal') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_true_metal" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_true_metal" } ]
      },
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_cold_pool') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_cold_pool" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_cold_pool" } ]
      },
      {
        "if": {
          "and": [
            { "math": [ "u_spell_level('immortal_path_meditate_blood_fiend') > -1" ] },
            { "not": { "u_has_trait": "immortal_path_body_blood_fiend" } }
          ]
        },
        "then": [ { "u_add_trait": "immortal_path_body_blood_fiend" } ]
      }
    ]
  }
]
